# Token de vérification (invente un mot secret, ex: monbot123)
VERIFY_TOKEN=ton_verify_token_secret

# Clé secrète de ton App Meta (App Secret)
APP_SECRET=ton_app_secret_meta

# Token d'accès Instagram (Page Access Token)
INSTAGRAM_ACCESS_TOKEN=ton_instagram_access_token

# Clé API OpenAI
OPENAI_API_KEY=sk-...ta_cle_openai

# Modèle OpenAI à utiliser (gpt-4o-mini = moins cher, gpt-4o = plus puissant)
OPENAI_MODEL=gpt-4o-mini

# Personnalité / instructions du bot (optionnel, sinon valeur par défaut utilisée)
SYSTEM_PROMPT=Tu es un assistant Instagram professionnel pour [NOM DE TA MARQUE]. Réponds de façon concise et amicale. Mets en avant les services suivants : [TES SERVICES].

# Port du serveur (5000 par défaut)
PORT=5000
